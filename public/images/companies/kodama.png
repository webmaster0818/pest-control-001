          <li class="bnr"><a href="https://www.izakayakodama.com/" target="_blank" onclick="gtag('event','click',{'event_category':'Links','event_label':'btn_izakayakodama'});"><img src="shared/img/index/s3_bnr_01.jpg" alt="沖縄そば" width="480" height="220" loading="lazy"/></a></li>
